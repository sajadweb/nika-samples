                "subject": {
                    "type": "string",
                    "maxLength": 255,
                    "minLength": 1
                }
            }
        },
        "dto.UpdatePostDto": {
            "type": "object",
            "properties": {
                "description": {
                    "type": "string"
                },
                "subject": {
                    "type": "string"
                }
            }
        },
        "response.CreateResponse": {
            "type": "object",
